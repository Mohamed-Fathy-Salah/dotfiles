#!/bin/bash

hijri_file=~/.cache/hijri_date

init() { source ~/.local/bin/sb-prayer-cache; }

case $BLOCK_BUTTON in
    1) birth="1999-08-18"
       now=$(date +%Y-%m-%d)
       y1=${birth%%-*}; m1=$(echo $birth | cut -d- -f2); d1=${birth##*-}
       y2=${now%%-*}; m2=$(echo $now | cut -d- -f2); d2=${now##*-}
       m1=${m1#0}; d1=${d1#0}; m2=${m2#0}; d2=${d2#0}
       dy=$((y2-y1)); dm=$((m2-m1)); dd=$((d2-d1))
       if [ $dd -lt 0 ]; then dm=$((dm-1)); dd=$((dd+30)); fi
       if [ $dm -lt 0 ]; then dy=$((dy-1)); dm=$((dm+12)); fi
       echo "${dy}y ${dm}m ${dd}d";;
    3) init
       cat $hijri_file;;
    *) date "+%a %d %b" ;;
esac
