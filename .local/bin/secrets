#!/bin/bash

chosen=$(ls ~/.local/share/pass/*.gpg 2>/dev/null | xargs -I {} basename {} .gpg | dmenu -i -p "Choose password: ")

if [ -z "$chosen" ]; then
    exit 0
fi

if echo "$chosen" | grep -qi "2fo"; then
    oathtool --base32 --totp "$(pass "$chosen")" | xclip -selection clipboard && xdotool key ctrl+v
else
    pass -c "$chosen" && xdotool key ctrl+v
fi
