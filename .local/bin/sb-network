#!/bin/zsh

IFACE=$(ip route show default | sort -k5 -n | awk '{print $5; exit}')

WIFI_IF=wlp3s0
ETH_IF=eno1

case $BLOCK_BUTTON in
    1)
        choice=$(printf "ethernet\nwifi" | dmenu -p 'Connect via:')

        case "$choice" in
            wifi)
                sudo ip link set "$ETH_IF" down 2>/dev/null
                sudo dhcpcd -k "$ETH_IF" 2>/dev/null

                sudo ip link set "$WIFI_IF" up
                sudo dhcpcd "$WIFI_IF"

                ssid=$(wpa_cli list_networks | tail -n +3 \
                    | awk -F'\t' '{print $2}' \
                    | dmenu -p 'Select Wi-Fi:')

                id=$(wpa_cli list_networks \
                    | awk -v ssid="$ssid" -F'\t' '$2==ssid {print $1}')

                [[ -n "$id" ]] && wpa_cli select_network "$id"
                ;;
            ethernet)
                sudo dhcpcd -k "$WIFI_IF" 2>/dev/null
                sudo ip link set "$WIFI_IF" down

                sudo ip link set "$ETH_IF" up
                sudo dhcpcd "$ETH_IF"
                ;;
        esac
        ;;
    3)
        [[ "$IFACE" == wl* ]] && wpa_cli status | awk -F= '/^ssid=/ {print $2}'
        exit 0
        ;;
esac

ICON=$([[ "$IFACE" == wl* ]] && echo "直" || echo "󰈀")

awk -v iface="$IFACE" -v icon="$ICON" '
$1 ~ iface":" {
    i++
    recv[i]=$2
    trans[i]=$10
}
END {
    printf "▼ %.1f KB %s %.1f KB ▲",
    (recv[2]-recv[1])/1024,
    icon,
    (trans[2]-trans[1])/1024
}
' <(cat /proc/net/dev; sleep 1; cat /proc/net/dev)
