#!/bin/zsh

sink="@DEFAULT_SINK@"

case $BLOCK_BUTTON in
    1) pactl set-sink-mute $sink toggle;;
    3) st -e alsamixer -c 0;;
    4) pactl set-sink-volume $sink +1%;;
    5) pactl set-sink-volume $sink -1%;;
esac

if [ "$(pactl get-sink-mute $sink)" = "Mute: yes" ]; then
    echo "󰖁 "
else
    vol=$(pactl get-sink-volume $sink | grep -oP '\d+(?=%)' | head -1)
    echo "󰕾 ${vol}%"
fi
